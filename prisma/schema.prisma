generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LeadSource {
  Foodics
  EmployeeReferral
  CustomerReferral
  PartnerReferral
  Website
  AmbassadorReferral
  DirectSales
  Sonic
  Historical
}

enum ContractType {
  New
  Renewal
  Expansion
}

enum Role {
  CCO_ADMIN
  REVENUE_MANAGER
  CUSTOMER_SUCCESS
  READ_ONLY
}

enum ProductCategory {
  Plan
  AddOn
}

enum PaymentPlan {
  Yearly
  Quarterly
  OneTime
}

// ─── Pipeline Enums ───────────────────────────────────────────────────────────

enum LeadStage {
  Lead
  Qualified
  ClosedWon
  Expired
  ClosedLost
  Churned
}

// ─── Invoicing Enums ──────────────────────────────────────────────────────────

enum POSSystem {
  Foodics
  Geidea
  Sonic
}

enum InvoicePkg {
  Essential
  Operations
  Enterprise
}

enum InvoicePayType {
  Annual
  Quarterly
  Special
}

enum InvoiceStatus {
  Pending
  Eligible
  Collected
}

enum DealType {
  New
  Renewal
  Upsell
  Expansion
}

// ─── Country (dynamic DB table) ───────────────────────────────────────────────

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  currency  String
  isActive  Boolean  @default(true)
  vatRate   Decimal? @default(0) @db.Decimal(5, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  productPricing ProductPricing[]

  @@map("countries")
}

// ─── Account ──────────────────────────────────────────────────────────────────

model Account {
  id                  Int        @id @default(autoincrement())
  name                String
  leadSource          LeadSource
  countryId           Int
  brands              Int        @default(1)
  numberOfBranches    Int        @default(1)
  numberOfCostCentres Int?
  externalCode        String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  contracts       Contract[]
  country         Country                @relation(fields: [countryId], references: [id])
  leads           Lead[]
  deals           Deal[]
  onboarding      OnboardingTracker?
  handovers       HandoverDocument[]
  healthSnapshots AccountHealthSnapshot[]
  notes           AccountNote[]
  brandNames      AccountBrand[]
  engagementLogs  EngagementLog[]
  cases           EngagementCase[] @relation("AccountCases")

  @@map("accounts")
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id               Int          @id @default(autoincrement())
  accountId        Int
  contractValue    Decimal      @db.Decimal(14, 2)
  startDate        DateTime
  activationDate   DateTime?
  endDate          DateTime
  type             ContractType
  cancellationDate DateTime?
  usdRate          Decimal?     @db.Decimal(14, 6)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  account Account        @relation(fields: [accountId], references: [id])
  items   ContractItem[]
  deals   Deal[]

  @@map("contracts")
}

// ─── Contract Items ───────────────────────────────────────────────────────────

model ContractItem {
  id          Int         @id @default(autoincrement())
  contractId  Int
  productId   Int?
  description String
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(14, 2)
  discountPct Decimal?    @db.Decimal(5, 2)   // per-line discount %
  paymentPlan PaymentPlan
  lineTotal   Decimal     @db.Decimal(14, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])

  @@map("contract_items")
}

// ─── Product & Pricing ────────────────────────────────────────────────────────

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  category    ProductCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pricing       ProductPricing[]
  contractItems ContractItem[]

  @@map("products")
}

model ProductPricing {
  id            Int      @id @default(autoincrement())
  productId     Int
  countryId     Int
  price         Decimal  @db.Decimal(14, 2)
  currency      String
  effectiveFrom DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@map("product_pricing")
}

// ─── Exchange Rates (FX cache) ────────────────────────────────────────────────

model ExchangeRate {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  currency  String
  rateToUSD Decimal  @db.Decimal(14, 6)
  createdAt DateTime @default(now())

  @@unique([date, currency])
  @@map("exchange_rates")
}

// ─── Custom Roles (flexible named permission templates) ───────────────────────

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json     @default("{}")   // { module: { action: bool }, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("custom_roles")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(READ_ONLY)
  permissions   Json      @default("{}")    // per-user module overrides (layer 3)
  customRoleId  String?                     // optional custom role assignment (layer 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   NextAuthAccount[]
  sessions   Session[]
  deals      Deal[]
  leads      Lead[]       @relation("UserLeads")
  customRole CustomRole?  @relation(fields: [customRoleId], references: [id])

  // Onboarding staff assignments
  obTrackers      OnboardingTracker[] @relation("ObSpecialist")
  trTrackers      OnboardingTracker[] @relation("TrSpecialist")
  amTrackers      OnboardingTracker[] @relation("AccManager")
  engagementLogs  EngagementLog[]     @relation("UserEngagementLogs")
  openedCases     EngagementCase[]    @relation("UserOpenedCases")
  assignedCases   EngagementCase[]    @relation("UserAssignedCases")
  caseFollowUps   CaseFollowUp[]      @relation("UserFollowUps")

  @@map("users")
}

model NextAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("next_auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Invoicing: Pricing Tables (new — annual, by channel, with history) ──────

enum AddOnModule {
  CentralKitchen
  Warehouse
  AccountingMain
  AccountingExtra
  Butchering
  AIAgent
}

model InventoryPricing {
  id           Int        @id @default(autoincrement())
  countryCode  String
  salesChannel LeadSource
  package      InvoicePkg
  annualPrice  Decimal    @db.Decimal(14, 2)
  currency     String
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt    DateTime   @default(now())

  @@map("inventory_pricing")
}

model AddOnPricing {
  id           Int         @id @default(autoincrement())
  countryCode  String
  salesChannel LeadSource
  module       AddOnModule
  annualPrice  Decimal     @db.Decimal(14, 2)
  currency     String
  effectiveFrom DateTime   @default(now())
  effectiveTo   DateTime?
  createdAt    DateTime    @default(now())

  @@map("addon_pricing")
}

// ─── Invoicing: Deal (Sales Log) ──────────────────────────────────────────────

model Deal {
  id                    Int            @id @default(autoincrement())
  startDate             DateTime
  activationDate        DateTime?
  agentId               String?
  accountName           String
  brandNames            String?
  numberOfBrands        Int            @default(1)
  dealType              DealType
  posSystem             POSSystem?
  countryCode           String
  salesChannel          String?
  package               InvoicePkg?
  paymentType           InvoicePayType
  isHistorical          Boolean        @default(false)
  contractYears         Int?
  normalBranches        Int            @default(0)
  centralKitchens       Int            @default(0)
  warehouses            Int            @default(0)
  hasAccounting         Boolean        @default(false)
  extraAccountingBranches Int          @default(0)
  hasButchering         Boolean        @default(false)
  aiAgentUsers          Int            @default(0)
  notes                 String?

  discount              Decimal?       @db.Decimal(5, 2)   // overall deal discount %

  // Snapshot of calculated values at confirmation (immutable)
  totalMRR              Decimal        @db.Decimal(14, 2)
  vatRate               Decimal        @db.Decimal(5, 4)
  totalMRRInclVAT       Decimal        @db.Decimal(14, 2)
  contractMonths        Int
  contractValue         Decimal        @db.Decimal(14, 2)
  contractValueInclVAT  Decimal        @db.Decimal(14, 2)

  accountId  Int?
  contractId Int?     // direct link to the Contract record created for this deal
  createdAt  DateTime @default(now())

  agent      User?              @relation(fields: [agentId], references: [id])
  invoices   Invoice[]
  account    Account?           @relation(fields: [accountId], references: [id])
  contract   Contract?          @relation(fields: [contractId], references: [id])
  onboarding OnboardingTracker?
  handover   HandoverDocument?

  @@map("deals")
}

// ─── Invoicing: Invoice ───────────────────────────────────────────────────────

model Invoice {
  id                   Int            @id @default(autoincrement())
  invoiceNumber        String         @unique
  dealId               Int
  accountName          String
  posSystem            POSSystem
  countryCode          String
  paymentType          InvoicePayType
  dealDate             DateTime
  invoiceDate          DateTime
  quarterNumber        Int
  amountExclVAT        Decimal        @db.Decimal(14, 2)
  vatRate              Decimal        @db.Decimal(5, 4)
  vatAmount            Decimal        @db.Decimal(14, 2)
  amountInclVAT        Decimal        @db.Decimal(14, 2)
  foodicsInvoiceNumber String?
  eligibleCollectionDate DateTime?
  status               InvoiceStatus  @default(Pending)
  collectionDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("invoices")
}

// ─── Onboarding Enums ─────────────────────────────────────────────────────────

enum OnboardingPhase {
  DealClosure       // Stage 1 — Sales / Account Management
  Onboarding        // Stage 2 — Onboarding Team
  Training          // Stage 3 — Onboarding Team
  Incubation        // Stage 4 — Onboarding Team (2-week max)
  AccountManagement // Stage 5 — Customer Success Team
  Expired           // Stage 6 — Contracts lapsed, renewal in progress
  Churned           // Terminal — account has officially churned
}

// ─── Operations: Onboarding Tracker ──────────────────────────────────────────

model OnboardingTracker {
  id             Int             @id @default(autoincrement())
  accountId      Int             @unique
  dealId         Int?            @unique
  phase          OnboardingPhase @default(DealClosure)
  phaseStartedAt DateTime        @default(now())
  startDate      DateTime        @default(now())
  goLiveDate     DateTime?       // target AccountManagement date = Deal activationDate
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Staff assignments
  onboardingSpecialistId String?
  trainingSpecialistId   String?
  accountManagerId       String?

  account              Account            @relation(fields: [accountId], references: [id])
  deal                 Deal?              @relation(fields: [dealId], references: [id])
  tasks                OnboardingTask[]
  noteEntries          OnboardingNote[]
  csatRecords          CsatRecord[]
  npsRecords           NpsRecord[]
  onboardingSpecialist User?              @relation("ObSpecialist", fields: [onboardingSpecialistId], references: [id])
  trainingSpecialist   User?              @relation("TrSpecialist", fields: [trainingSpecialistId],   references: [id])
  accountManager       User?              @relation("AccManager",   fields: [accountManagerId],       references: [id])

  @@map("onboarding_trackers")
}

model OnboardingNote {
  id        Int               @id @default(autoincrement())
  trackerId Int
  content   String
  author    String?           // display name / email captured from session at write time
  createdAt DateTime          @default(now())

  tracker OnboardingTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@map("onboarding_notes")
}

model OnboardingTask {
  id             Int             @id @default(autoincrement())
  trackerId      Int
  phase          OnboardingPhase
  title          String
  completed      Boolean         @default(false)
  completedAt    DateTime?
  dueDays        Int?            // days from phaseStartedAt by which task should be done
  dueDate        DateTime?       // absolute due date (used for recurring task instances)
  recurring      Boolean         @default(false)
  recurrenceDays Int?            // days between recurrences (30 = monthly, 90 = quarterly)
  createdAt      DateTime        @default(now())

  tracker OnboardingTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

// CSAT: auto-created on every phase transition
model CsatRecord {
  id          Int             @id @default(autoincrement())
  trackerId   Int
  fromPhase   OnboardingPhase
  toPhase     OnboardingPhase
  score       Int?            // 1–5 satisfaction score
  notes       String?
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  tracker OnboardingTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@map("csat_records")
}

// NPS: seeded quarterly for all Incubation + AccountManagement accounts
model NpsRecord {
  id          Int             @id @default(autoincrement())
  trackerId   Int
  phase       OnboardingPhase // phase the account was in when NPS was triggered
  quarter     String          // e.g. "Q1-2026"
  score       Int?            // 0–10 NPS score
  notes       String?
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  tracker OnboardingTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@unique([trackerId, quarter])
  @@map("nps_records")
}

// ─── Pipeline: Lead ───────────────────────────────────────────────────────────

model Lead {
  id                Int         @id @default(autoincrement())
  companyName       String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  channel           LeadSource
  countryCode       String?
  estimatedValue    Decimal?    @db.Decimal(12, 2)
  numberOfBranches  Int?
  packageInterest   InvoicePkg?
  stage             LeadStage   @default(Lead)
  lostReason        String?
  notes             String?
  opportunityDate   DateTime    @default(now())
  expectedCloseDate DateTime?
  ownerId           String
  owner             User        @relation("UserLeads", fields: [ownerId], references: [id])
  opportunityType   DealType?
  accountId         Int?
  account           Account?    @relation(fields: [accountId], references: [id])
  convertedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("leads")
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        Int      @id @default(autoincrement())
  entity    String   // 'Lead', 'Deal', 'Tracker', 'Invoice'
  entityId  Int
  accountId Int?     // denormalized for fast account-timeline queries
  action    String   // 'stage_changed', 'closed_won', 'phase_changed', 'status_changed'
  actorId   String?  // User.id (nullable for system actions)
  actorName String?  // display name at time of action
  meta      Json?    // { from, to, notes, ... }
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([accountId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Account Health Snapshot ──────────────────────────────────────────────────

model AccountHealthSnapshot {
  id         Int      @id @default(autoincrement())
  accountId  Int
  score      Decimal  @db.Decimal(5, 2)   // 0–100
  label      String                        // 'Healthy' | 'Watch' | 'At Risk'
  csatScore  Decimal? @db.Decimal(5, 2)
  npsScore   Decimal? @db.Decimal(5, 2)
  taskPct    Decimal? @db.Decimal(5, 2)
  snappedAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, snappedAt])
  @@map("account_health_snapshots")
}

// ─── Internal Handover Document ───────────────────────────────────────────────

model HandoverDocument {
  id        Int      @id @default(autoincrement())
  dealId    Int      @unique
  accountId Int

  // Section 1 — Deal Summary (pre-filled from deal data)
  clientName         String
  contractStart      DateTime?
  contractDuration   String?
  commercialModel    String?

  // Section 2 — Key Contacts
  clientPoc          String?
  clientPocRole      String?
  clientEmail        String?
  clientPhone        String?
  escalationContact  String?
  acquisitionOwner   String?
  assignedCsManager  String?

  // Section 3 — Objectives & Success Criteria
  primaryObjectives  String?
  successMetrics     String?
  shortTermPriorities String?
  longTermPriorities  String?

  // Section 4 — Client Operations Snapshot
  howTheyOperate         String?
  orderWorkflowSummary   String?
  locationsOperatingHours String?

  // Section 5 — Pain Points & Needs
  keyNeeds      String?
  topPainPoints String?

  // Section 6 — Existing Systems
  currentSystemsUsed    String?
  requiredIntegrations  String?

  // Section 7 — Scope & Critical Notes
  inScope               String?
  outOfScope            String?
  dependenciesFromClient String?
  highlights            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal    Deal    @relation(fields: [dealId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@map("handover_documents")
}

// ─── Account Brands ───────────────────────────────────────────────────────────

model AccountBrand {
  id        Int      @id @default(autoincrement())
  accountId Int
  name      String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_brands")
}

// ─── Engagement Log Enums ─────────────────────────────────────────────────────

enum CommChannel {
  Whatsapp
  Call
  VirtualMeeting
  PhysicalMeeting
  Email
  Other
}

enum EngagementObjective {
  Inquiry
  BugReport
  TrainingRequest
  NewRequirement
  TechnicalRequest
  GlobalOutage
  Onboarding
  Training
}

// ─── Case / Ticketing Enums ───────────────────────────────────────────────────

enum CaseStatus {
  Open
  Resolved
  ClosedUnresolved
  Escalated
}

enum OutageStatus {
  Active
  Resolved
}

// ─── Account Notes ────────────────────────────────────────────────────────────

model AccountNote {
  id         Int      @id @default(autoincrement())
  accountId  Int
  content    String
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@map("account_notes")
}

// ─── Engagement Logs ──────────────────────────────────────────────────────────

model EngagementLog {
  id          Int                 @id @default(autoincrement())
  accountId   Int
  loggedById  String
  channel     CommChannel
  objective   EngagementObjective
  notes       String?
  loggedAt    DateTime
  startTime   DateTime?           // interaction start (date + time)
  endTime     DateTime?           // interaction end (date + time)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  account  Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  loggedBy User    @relation("UserEngagementLogs", fields: [loggedById], references: [id])

  @@index([accountId, loggedAt])
  @@index([loggedById])
  @@map("engagement_logs")
}

// ─── Engagement Cases (Ticketing) ─────────────────────────────────────────────

model EngagementCase {
  id           Int                 @id @default(autoincrement())
  accountId    Int?
  openedById   String
  assignedToId String?
  channel      CommChannel
  objective    EngagementObjective
  title        String
  description  String?
  status       CaseStatus          @default(Open)
  openedAt     DateTime            @default(now())
  resolvedAt   DateTime?
  outageStatus OutageStatus?
  outageId     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     Account?         @relation("AccountCases",      fields: [accountId],    references: [id])
  openedBy    User             @relation("UserOpenedCases",   fields: [openedById],   references: [id])
  assignedTo  User?            @relation("UserAssignedCases", fields: [assignedToId], references: [id])
  followUps   CaseFollowUp[]
  outage      EngagementCase?  @relation("OutageCases",       fields: [outageId],     references: [id])
  linkedCases EngagementCase[] @relation("OutageCases")

  @@index([accountId, openedAt])
  @@index([outageId])
  @@index([status])
  @@index([objective])
  @@map("engagement_cases")
}

model CaseFollowUp {
  id          Int          @id @default(autoincrement())
  caseId      Int
  authorId    String
  channel     CommChannel?
  actionTaken String?
  notes       String?
  loggedAt    DateTime
  createdAt   DateTime     @default(now())

  case   EngagementCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User           @relation("UserFollowUps", fields: [authorId], references: [id])

  @@index([caseId, loggedAt])
  @@map("case_follow_ups")
}
