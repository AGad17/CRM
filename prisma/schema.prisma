generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LeadSource {
  Foodics
  EmployeeReferral
  CustomerReferral
  PartnerReferral
  Website
  AmbassadorReferral
  DirectSales
  Sonic
}

enum Country {
  KSA
  Egypt
  UAE
  Bahrain
  Jordan
}

enum ContractType {
  New
  Renewal
  Expansion
}

enum Role {
  CCO_ADMIN
  REVENUE_MANAGER
  CUSTOMER_SUCCESS
  READ_ONLY
}

// ─── Account ──────────────────────────────────────────────────────────────────

model Account {
  id                  Int        @id @default(autoincrement())
  name                String
  leadSource          LeadSource
  country             Country
  brands              Int        @default(1)
  numberOfBranches    Int        @default(1)
  numberOfCostCentres Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  contracts Contract[]

  @@map("accounts")
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id               Int          @id @default(autoincrement())
  accountId        Int
  contractValue    Decimal      @db.Decimal(14, 2)
  startDate        DateTime
  endDate          DateTime
  type             ContractType
  cancellationDate DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@map("contracts")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(READ_ONLY)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts NextAuthAccount[]
  sessions Session[]

  @@map("users")
}

model NextAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("next_auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
