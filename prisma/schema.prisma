generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LeadSource {
  Foodics
  EmployeeReferral
  CustomerReferral
  PartnerReferral
  Website
  AmbassadorReferral
  DirectSales
  Sonic
}

enum ContractType {
  New
  Renewal
  Expansion
}

enum Role {
  CCO_ADMIN
  REVENUE_MANAGER
  CUSTOMER_SUCCESS
  READ_ONLY
}

enum ProductCategory {
  Plan
  AddOn
}

enum PaymentPlan {
  Yearly
  Quarterly
  OneTime
}

// ─── Country (dynamic DB table) ───────────────────────────────────────────────

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  currency  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  productPricing ProductPricing[]

  @@map("countries")
}

// ─── Account ──────────────────────────────────────────────────────────────────

model Account {
  id                  Int        @id @default(autoincrement())
  name                String
  leadSource          LeadSource
  countryId           Int
  brands              Int        @default(1)
  numberOfBranches    Int        @default(1)
  numberOfCostCentres Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  contracts Contract[]
  country   Country    @relation(fields: [countryId], references: [id])

  @@map("accounts")
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id               Int          @id @default(autoincrement())
  accountId        Int
  contractValue    Decimal      @db.Decimal(14, 2)
  startDate        DateTime
  endDate          DateTime
  type             ContractType
  cancellationDate DateTime?
  usdRate          Decimal?     @db.Decimal(14, 6)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  account Account        @relation(fields: [accountId], references: [id])
  items   ContractItem[]

  @@map("contracts")
}

// ─── Contract Items ───────────────────────────────────────────────────────────

model ContractItem {
  id          Int         @id @default(autoincrement())
  contractId  Int
  productId   Int?
  description String
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(14, 2)
  paymentPlan PaymentPlan
  lineTotal   Decimal     @db.Decimal(14, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])

  @@map("contract_items")
}

// ─── Product & Pricing ────────────────────────────────────────────────────────

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  category    ProductCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pricing       ProductPricing[]
  contractItems ContractItem[]

  @@map("products")
}

model ProductPricing {
  id            Int      @id @default(autoincrement())
  productId     Int
  countryId     Int
  price         Decimal  @db.Decimal(14, 2)
  currency      String
  effectiveFrom DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@map("product_pricing")
}

// ─── Exchange Rates (FX cache) ────────────────────────────────────────────────

model ExchangeRate {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  currency  String
  rateToUSD Decimal  @db.Decimal(14, 6)
  createdAt DateTime @default(now())

  @@unique([date, currency])
  @@map("exchange_rates")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(READ_ONLY)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts NextAuthAccount[]
  sessions Session[]

  @@map("users")
}

model NextAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("next_auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
