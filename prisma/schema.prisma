generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LeadSource {
  Foodics
  EmployeeReferral
  CustomerReferral
  PartnerReferral
  Website
  AmbassadorReferral
  DirectSales
  Sonic
}

enum ContractType {
  New
  Renewal
  Expansion
}

enum Role {
  CCO_ADMIN
  REVENUE_MANAGER
  CUSTOMER_SUCCESS
  READ_ONLY
}

enum ProductCategory {
  Plan
  AddOn
}

enum PaymentPlan {
  Yearly
  Quarterly
  OneTime
}

// ─── Pipeline Enums ───────────────────────────────────────────────────────────

enum LeadStage {
  Lead
  Qualified
  ClosedWon
  ClosedLost
  Churned
}

// ─── Invoicing Enums ──────────────────────────────────────────────────────────

enum POSSystem {
  Foodics
  Geidea
  Sonic
}

enum InvoicePkg {
  Essential
  Operations
  Enterprise
}

enum InvoicePayType {
  Annual
  Quarterly
  Special
}

enum InvoiceStatus {
  Pending
  Eligible
  Collected
}

enum DealType {
  New
  Renewal
  Upsell
}

enum BranchType {
  Normal
  CentralKitchen
  Warehouse
}

// ─── Country (dynamic DB table) ───────────────────────────────────────────────

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  currency  String
  isActive  Boolean  @default(true)
  vatRate   Decimal? @default(0) @db.Decimal(5, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  productPricing ProductPricing[]

  @@map("countries")
}

// ─── Account ──────────────────────────────────────────────────────────────────

model Account {
  id                  Int        @id @default(autoincrement())
  name                String
  leadSource          LeadSource
  countryId           Int
  brands              Int        @default(1)
  numberOfBranches    Int        @default(1)
  numberOfCostCentres Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  contracts  Contract[]
  country    Country            @relation(fields: [countryId], references: [id])
  lead       Lead?
  deals      Deal[]
  onboarding OnboardingTracker?

  @@map("accounts")
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id               Int          @id @default(autoincrement())
  accountId        Int
  contractValue    Decimal      @db.Decimal(14, 2)
  startDate        DateTime
  endDate          DateTime
  type             ContractType
  cancellationDate DateTime?
  usdRate          Decimal?     @db.Decimal(14, 6)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  account Account        @relation(fields: [accountId], references: [id])
  items   ContractItem[]

  @@map("contracts")
}

// ─── Contract Items ───────────────────────────────────────────────────────────

model ContractItem {
  id          Int         @id @default(autoincrement())
  contractId  Int
  productId   Int?
  description String
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(14, 2)
  paymentPlan PaymentPlan
  lineTotal   Decimal     @db.Decimal(14, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])

  @@map("contract_items")
}

// ─── Product & Pricing ────────────────────────────────────────────────────────

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  category    ProductCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pricing       ProductPricing[]
  contractItems ContractItem[]

  @@map("products")
}

model ProductPricing {
  id            Int      @id @default(autoincrement())
  productId     Int
  countryId     Int
  price         Decimal  @db.Decimal(14, 2)
  currency      String
  effectiveFrom DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@map("product_pricing")
}

// ─── Exchange Rates (FX cache) ────────────────────────────────────────────────

model ExchangeRate {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  currency  String
  rateToUSD Decimal  @db.Decimal(14, 6)
  createdAt DateTime @default(now())

  @@unique([date, currency])
  @@map("exchange_rates")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(READ_ONLY)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts NextAuthAccount[]
  sessions Session[]
  deals    Deal[]
  leads    Lead[]    @relation("UserLeads")

  @@map("users")
}

model NextAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("next_auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Invoicing: Pricing Tables ────────────────────────────────────────────────

model BranchPricing {
  id          Int        @id @default(autoincrement())
  countryCode String
  package     InvoicePkg
  branchType  BranchType
  price       Decimal    @db.Decimal(14, 2)
  currency    String

  @@unique([countryCode, package, branchType])
  @@map("branch_pricing")
}

model AccountingPricing {
  id            Int        @id @default(autoincrement())
  countryCode   String
  package       InvoicePkg
  isMainLicense Boolean
  price         Decimal    @db.Decimal(14, 2)
  currency      String

  @@unique([countryCode, package, isMainLicense])
  @@map("accounting_pricing")
}

model FlatModulePricing {
  id          Int     @id @default(autoincrement())
  countryCode String
  module      String  // Butchering | AIAgent
  price       Decimal @db.Decimal(14, 2)
  currency    String

  @@unique([countryCode, module])
  @@map("flat_module_pricing")
}

// ─── Invoicing: Deal (Sales Log) ──────────────────────────────────────────────

model Deal {
  id                    Int            @id @default(autoincrement())
  startDate             DateTime
  agentId               String
  accountName           String
  brandNames            String
  numberOfBrands        Int            @default(1)
  dealType              DealType
  posSystem             POSSystem
  countryCode           String
  salesChannel          String?
  package               InvoicePkg
  paymentType           InvoicePayType
  contractYears         Int?
  normalBranches        Int            @default(0)
  centralKitchens       Int            @default(0)
  warehouses            Int            @default(0)
  hasAccounting         Boolean        @default(false)
  extraAccountingBranches Int          @default(0)
  hasButchering         Boolean        @default(false)
  aiAgentUsers          Int            @default(0)
  notes                 String?

  // Snapshot of calculated values at confirmation (immutable)
  totalMRR              Decimal        @db.Decimal(14, 2)
  vatRate               Decimal        @db.Decimal(5, 4)
  totalMRRInclVAT       Decimal        @db.Decimal(14, 2)
  contractMonths        Int
  contractValue         Decimal        @db.Decimal(14, 2)
  contractValueInclVAT  Decimal        @db.Decimal(14, 2)

  accountId Int?
  createdAt DateTime @default(now())

  agent      User               @relation(fields: [agentId], references: [id])
  invoices   Invoice[]
  account    Account?           @relation(fields: [accountId], references: [id])
  onboarding OnboardingTracker?

  @@map("deals")
}

// ─── Invoicing: Invoice ───────────────────────────────────────────────────────

model Invoice {
  id                   Int            @id @default(autoincrement())
  invoiceNumber        String         @unique
  dealId               Int
  accountName          String
  posSystem            POSSystem
  countryCode          String
  paymentType          InvoicePayType
  dealDate             DateTime
  invoiceDate          DateTime
  quarterNumber        Int
  amountExclVAT        Decimal        @db.Decimal(14, 2)
  vatRate              Decimal        @db.Decimal(5, 4)
  vatAmount            Decimal        @db.Decimal(14, 2)
  amountInclVAT        Decimal        @db.Decimal(14, 2)
  foodicsInvoiceNumber String?
  eligibleCollectionDate DateTime?
  status               InvoiceStatus  @default(Pending)
  collectionDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("invoices")
}

// ─── Onboarding Enums ─────────────────────────────────────────────────────────

enum OnboardingPhase {
  WelcomeCall
  Onboarding
  Training
  Incubation
  Active
}

// ─── Operations: Onboarding Tracker ──────────────────────────────────────────

model OnboardingTracker {
  id        Int             @id @default(autoincrement())
  accountId Int             @unique
  dealId    Int             @unique
  phase     OnboardingPhase @default(WelcomeCall)
  startDate DateTime        @default(now())
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  account Account         @relation(fields: [accountId], references: [id])
  deal    Deal            @relation(fields: [dealId], references: [id])
  tasks   OnboardingTask[]

  @@map("onboarding_trackers")
}

model OnboardingTask {
  id          Int             @id @default(autoincrement())
  trackerId   Int
  phase       OnboardingPhase
  title       String
  completed   Boolean         @default(false)
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  tracker OnboardingTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

// ─── Pipeline: Lead ───────────────────────────────────────────────────────────

model Lead {
  id                Int         @id @default(autoincrement())
  companyName       String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  channel           LeadSource
  countryCode       String?
  estimatedValue    Decimal?    @db.Decimal(12, 2)
  packageInterest   InvoicePkg?
  stage             LeadStage   @default(Lead)
  lostReason        String?
  notes             String?
  expectedCloseDate DateTime?
  ownerId           String
  owner             User        @relation("UserLeads", fields: [ownerId], references: [id])
  accountId         Int?        @unique
  account           Account?    @relation(fields: [accountId], references: [id])
  convertedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("leads")
}
